{% comment %} Custom Banner – all text editable; vanilla CSS animation on button {% endcomment %}
<section class="cbanner cbanner--{{ section.settings.align }}">
  {% if section.settings.banner_image != blank %}
    <div class="cbanner__bg">
      <img
        loading="eager"
        src="{{ section.settings.banner_image | image_url: width: 2400 }}"
        alt="Banner"
        width="{{ section.settings.banner_image.width }}"
        height="{{ section.settings.banner_image.height }}"
      />
    </div>
  {% endif %}

  <div class="cbanner__inner page-width">
    <h1 class="cbanner__heading">{{ section.settings.heading }}</h1>
    {% if section.settings.subheading != blank %}
      <p class="cbanner__sub">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="cbanner__btn" data-anim="pulse">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "image_picker", "id": "banner_image", "label": "Banner image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Gift Guide" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Browse our latest products" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop all" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select", "id": "align", "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    }
  ],
  "presets": [{ "name": "Custom Banner" }]
}
{% endschema %}
